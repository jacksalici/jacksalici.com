---
import { getCollection } from "astro:content";
import PostCard from "../components/PostCard.astro";
import GlassChip from "../components/GlassChip.astro";
import Base from "../layouts/Base.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { FileText, Hammer, PenLine, Github, GraduationCap, Linkedin } from "@lucide/astro";
import "../styles/global.css";


const recentAll = [
  ...(await getCollection("notes"))
    .filter((a) => a.data.draft !== true && a.data.hidden !== true)
    .map((a) => ({ date: a.data.pubDate, featured: a.data.featured ?? false, text: a.data.news ?? a.data.description ?? a.data.title ?? "", slug: "/notes/" + a.slug, type: "note" as const })),
  ...(await getCollection("projects"))
    .filter((a) => a.data.draft !== true && a.data.hidden !== true)
    .map((a) => ({ date: a.data.pubDate, featured: a.data.featured ?? false, text: a.data.news ?? a.data.description ?? a.data.title ?? "", slug: "/projects/" + a.slug, type: "project" as const })),
  ...(await getCollection("papers"))
    .filter((a) => a.data.draft !== true && a.data.hidden !== true)
    .map((a) => ({ date: a.data.pubDate, featured: a.data.featured ?? false, text: a.data.news ?? a.data.description ?? a.data.title ?? "", slug: "/papers/" + a.slug, type: "paper" as const })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

const props = { image: "/sky.png" };
---

<Base image={props.image}>
  <main>
    <h1 class="text-4xl text-balance">
      A digital craftsman who designs systems that matter.
    </h1>

   

    <div class="mt-10 mb-10 flex flex-col gap-4">
      <p>I am
        <span class="font-bold">Giacomo Salici</span>
        <sup class="font-light text-[10px]">/'d͡ʒa‧ko‧mo-sa‧li‧t͡ʃi/</sup>, an AI
        &amp; computer engineer, developer, and occasionally designer based in Italy. I work with the <a
          href="https://aimagelab.unimore.it/">AImageLab</a> research group of University of Modena and Reggio Emilia as a <span class="font-bold">PhD candidate in ICT</span>.
      </p>
      <p>
        My research interests include <span class="text-accent-2 font-bold">artificial intelligence of things (AIoT), modular deep learning, and anomaly detection.</span>
      
        Besides my research work, I also enjoy (in casual order): open-source software and hardware, good designs (digital and physical), to craft random stuff, 3D printing, the outdoors, swimming, DnD, pizza, and desk plants.
        If you want to get in touch, feel free to <a href="/contacts">reach out&nbsp;↗</a>.
      </p>
       <div class="mt-6 flex gap-3">
      <a href="https://github.com/jacksalici" class="hover:text-accent-1 transition-colors">
        <Github size={20} />
      </a>
      <a href="https://scholar.google.com/citations?user=jMVa-rYAAAAJ" class="hover:text-accent-1 transition-colors">
        <GraduationCap size={20} />
      </a>
      <a href="https://linkedin.com/in/giacomosalici" class="hover:text-accent-1 transition-colors">
        <Linkedin size={20} />
      </a>
    </div>
    </div>

    <div class="min-h-[80vh] mt-20" id="feed">
      <div class="mb-10 flex flex-wrap items-center gap-y-3 ">
        <h1 class="text-3xl">Thoughts, papers, & projects.</h1>
        <div class="flex gap-2 items-center md:ml-auto">
          <select id="filter-select" class="text-xs px-1 py-1 rounded-lg border border-base-300 text-neutral bg-base-100 hover:border-base-content hover:text-base-content transition-colors cursor-pointer focus:outline-none">
            <option value="all">All types</option>
            <option value="note">Notes</option>
            <option value="project">Projects</option>
            <option value="paper">Papers</option>
          </select>
          <select id="sort-select" class="text-xs px-1 py-1 rounded-lg border border-base-300 text-neutral bg-base-100 hover:border-base-content hover:text-base-content transition-colors cursor-pointer focus:outline-none">
            <option value="newest">Newest first</option>
            <option value="featured">Featured first</option>
          </select>
        </div>
      </div>

      <div class="flex flex-col gap-8">
        {
          recentAll.map((item) => (
            <a
              href={item.slug}
              class="feed-item group flex gap-2 items-start"
              data-type={item.type}
              data-date={item.date.valueOf()}
              data-featured={item.featured ? "1" : "0"}
            >
                <span class={`group-hover:text-accent-1 transition-colors mt-1 ${item.featured ? "text-accent-3" : ""}`}>
                {item.type === "paper"   && <FileText size={16} />}
                {item.type === "project" && <Hammer   size={16} />}
                {item.type === "note"    && <PenLine  size={16} />}
                </span>
              <p class="group-hover:text-accent-1 transition-colors text-balance">
                <span>{item.text}</span>
                {item.date && (
                  <span class="text-xs ml-1.5 opacity-50 inline-block">
                    <FormattedDate date={item.date} />
                  </span>
                )}
              </p>
            </a>
          ))
        }
      </div>
    </div>


    </div>
    <script>
      const feed = document.getElementById("feed")!;
      const filterSelect = document.getElementById("filter-select") as HTMLSelectElement;
      const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;

      let activeFilter = "all";

      function applyFilter() {
        const items = feed.querySelectorAll<HTMLElement>(".feed-item");
        items.forEach((item) => {
          const match = activeFilter === "all" || item.dataset.type === activeFilter;
          item.style.display = match ? "" : "none";
        });
      }

      function applySort(order: "newest" | "featured") {
        const items = Array.from(feed.querySelectorAll<HTMLElement>(".feed-item"));
        items.sort((a, b) => {
          if (order === "featured") {
            const fa = Number(a.dataset.featured);
            const fb = Number(b.dataset.featured);
            if (fb !== fa) return fb - fa;
          }
          return Number(b.dataset.date) - Number(a.dataset.date);
        });
        items.forEach((item) => feed.appendChild(item));
      }

      filterSelect.addEventListener("change", () => {
        activeFilter = filterSelect.value;
        applyFilter();
      });

      sortSelect.addEventListener("change", () => {
        applySort(sortSelect.value as "newest" | "featured");
        applyFilter();
      });
    </script>
  </main>

</Base>
