---
interface MenuItem {
  href: string
  label: string
  ariaLabel?: string
}

interface Props {
  href?: string
  label: string
  ariaLabel?: string
  full?: boolean
  highlight?: boolean
  dropdown?: boolean
  menuItems?: MenuItem[]
}

const { href, label, ariaLabel, full, highlight, dropdown = false, menuItems = [] } = Astro.props

import { cva } from "class-variance-authority";

const badgeVariants = cva(
  "inline-flex items-center gap-2 rounded-xl font-medium transition-all duration-100 focus:outline-none focus:ring-2 focus:ring-base-content/20 bg-gradient-to-br from-transparent to-transparent border hover:from-accent-2/15 hover:border-accent-2/50 hover:text-accent-2 hover:shadow-sm",
  {
    variants: {
      color: {
        default: "text-neutral-content border-neutral-content",
        highlight: "text-accent-3/90 from-accent-3 border-accent-3/15",
      },
      size: {
        default: "",
        full: "w-full justify-center",
      },
    },
    defaultVariants: { color: "default", size: "default" },
  }
);

const classes = badgeVariants({
  color: highlight ? "highlight" : "default",
  size: full ? "full" : "default",
});
---

{dropdown ? (
  <div class="relative inline-block group">
    <button aria-label={ariaLabel ?? label} class:list={[classes, "cursor-pointer"]}>
      <slot name="icon" />
      {label}
    </button>
    <div class="absolute right-0 mt-2 flex flex-col gap-1 rounded-3xl p-1 invisible -translate-y-2 transition-all duration-300 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 group-focus-within:opacity-100 group-focus-within:visible group-focus-within:translate-y-0">
      {menuItems.map((item) => (
        <a href={item.href} aria-label={item.ariaLabel ?? item.label} class:list={[badgeVariants({ color: highlight ? "highlight" : "default", size: "full" }), "whitespace-nowrap"]}>
          {item.label}
        </a>
      ))}
    </div>
  </div>
) : (
  <a
    href={href}
    target={href?.startsWith("http") ? "_blank" : "_self"}
    rel="noopener"
    aria-label={ariaLabel ?? label}
    class:list={[classes]}
  >
    <slot name="icon" />
    {label}
  </a>
)}
